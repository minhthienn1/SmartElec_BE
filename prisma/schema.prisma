generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                        @id @default(autoincrement())
  phoneNumber         String                     @unique
  password            String
  fullName            String?
  email               String?                    @unique
  avatarUrl           String?
  address             String?
  role                UserRole                   @default(USER)
  isVerified          Boolean                    @default(false)
  isActive            Boolean                    @default(true)
  lastLogin           DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  gender              Gender
  averageRating       Float                      @default(0.0)
  fcmToken            String?
  googleId            String?                    @unique
  isOnline            Boolean                    @default(false)
  latitude            Float?
  longitude           Float?
  needsPassword       Boolean                    @default(false)
  totalReviews        Int                        @default(0)
  zaloId              String?                    @unique
  technicianSessions  ChatSession[]              @relation("TechnicianSessions")
  chatSessions        ChatSession[]              @relation("CustomerSessions")
  devices             Device[]
  sentMessages        Message[]                  @relation("SentMessages")
  quotesCreated       Quote[]
  rag_documents       rag_documents[]
  reviewsReceived     Review[]                   @relation("TechnicianReviews")
  reviewsGiven        Review[]                   @relation("UserReviews")
  assignmentHistories SessionAssignmentHistory[]

  @@map("users")
}

model Device {
  id                     Int           @id @default(autoincrement())
  category               String
  brandName              String
  modelCode              String?
  location               String?
  purchaseDate           DateTime?
  warrantyMonths         Int?
  maintenanceCycleMonths Int?
  nextMaintenanceDate    DateTime?
  userId                 Int
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  chatSessions           ChatSession[]
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model ChatSession {
  id                  Int                        @id @default(autoincrement())
  deviceType          String?
  symptom             String?
  aiSummary           String?
  isDangerous         Boolean                    @default(false)
  userId              Int
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deviceId            Int?
  address             String?
  contactName         String?
  contactPhone        String?
  isHiddenByCustomer  Boolean                    @default(false)
  latitude            Float?
  longitude           Float?
  status              JobStatus                  @default(AI_CONSULTING)
  technicianId        Int?
  version             Int                        @default(1)
  sessionType         SessionType                @default(AI_DIAGNOSIS)
  device              Device?                    @relation(fields: [deviceId], references: [id])
  technician          User?                      @relation("TechnicianSessions", fields: [technicianId], references: [id])
  user                User                       @relation("CustomerSessions", fields: [userId], references: [id], onDelete: Cascade)
  messages            Message[]
  quotes              Quote[]
  review              Review?
  assignmentHistories SessionAssignmentHistory[]

  @@map("chat_sessions")
}

model Review {
  id           Int         @id @default(autoincrement())
  sessionId    Int         @unique
  userId       Int
  technicianId Int
  rating       Int
  comment      String?
  tags         String[]
  createdAt    DateTime    @default(now())
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  technician   User        @relation("TechnicianReviews", fields: [technicianId], references: [id])
  user         User        @relation("UserReviews", fields: [userId], references: [id])

  @@map("reviews")
}

model Message {
  id        Int         @id @default(autoincrement())
  sessionId Int
  senderId  Int?
  type      MessageType @default(TEXT)
  content   String
  metadata  Json?
  isRead    Boolean     @default(false)
  isDeleted Boolean     @default(false)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  sender    User?       @relation("SentMessages", fields: [senderId], references: [id])
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Quote {
  id            Int         @id @default(autoincrement())
  sessionId     Int
  technicianId  Int
  title         String
  amount        Float
  status        QuoteStatus @default(PENDING)
  version       Int         @default(1)
  parentQuoteId Int?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  technician    User        @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@map("quotes")
}

model SessionAssignmentHistory {
  id            Int              @id @default(autoincrement())
  chatSessionId Int
  technicianId  Int
  action        AssignmentAction
  createdAt     DateTime         @default(now())
  chatSession   ChatSession      @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  technician    User             @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@map("session_assignment_history")
}

model AiReasoningLog {
  id                  Int                   @id @default(autoincrement())
  sessionId           Int?
  userId              Int
  userMsg             String
  prevState           Json?
  nextState           Json?
  riskLevel           String?
  aiResponse          String?
  aiFeedback          String?
  score               Int                   @default(0)
  deviceCategory      String?
  isGolden            Boolean               @default(false)
  createdAt           DateTime              @default(now())
  ai_retrieved_chunks ai_retrieved_chunks[]

  @@map("ai_reasoning_logs")
}

model TechnicalDocument {
  id          Int                    @id @default(autoincrement())
  title       String
  content     String
  category    String?
  source      String?
  embedding   Unsupported("vector")?
  accessLevel AccessLevel            @default(ADVANCED)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@map("technical_documents")
}

model ai_retrieved_chunks {
  id                Int            @id @default(autoincrement())
  logId             Int
  chunkId           Int
  score             Float?
  rank              Int?
  createdAt         DateTime       @default(now())
  rag_chunks        rag_chunks     @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  ai_reasoning_logs AiReasoningLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@unique([logId, chunkId])
  @@index([chunkId])
  @@index([logId])
}

model rag_chunks {
  id                  Int                    @id @default(autoincrement())
  documentId          Int
  chunkIndex          Int
  title               String?
  section             String?
  content             String
  pageNumber          Int?
  sheetName           String?
  rowIndex            Int?
  metadata            Json?
  category            String?
  brand               String?
  modelCode           String?
  tags                String[]
  accessLevel         AccessLevel            @default(ADVANCED)
  tokenCount          Int?
  charCount           Int?
  embedding           Unsupported("vector")?
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime
  ai_retrieved_chunks ai_retrieved_chunks[]
  rag_documents       rag_documents          @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([accessLevel])
  @@index([brand])
  @@index([category])
  @@index([documentId])
  @@index([isActive])
}

model rag_documents {
  id               Int               @id @default(autoincrement())
  title            String
  description      String?
  originalFileName String?
  storedFileName   String?
  fileUrl          String?
  storageKey       String?
  mimeType         String?
  fileType         RagFileType       @default(UNKNOWN)
  fileSizeBytes    BigInt?
  checksum         String?
  kind             RagDocumentKind?
  category         String?
  brand            String?
  modelCode        String?
  source           String?
  tags             String[]
  accessLevel      AccessLevel       @default(ADVANCED)
  status           RagDocumentStatus @default(UPLOADED)
  errorMessage     String?
  totalChunks      Int               @default(0)
  totalCharacters  Int               @default(0)
  totalTokens      Int               @default(0)
  version          Int               @default(1)
  isActive         Boolean           @default(true)
  uploadedById     Int?
  parsedAt         DateTime?
  indexedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  rag_chunks       rag_chunks[]
  users            User?             @relation(fields: [uploadedById], references: [id])

  @@index([accessLevel])
  @@index([brand])
  @@index([category])
  @@index([checksum])
  @@index([isActive])
  @@index([kind])
  @@index([status])
  @@index([uploadedById])
}

enum UserRole {
  USER
  TECHNICIAN
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum JobStatus {
  AI_CONSULTING
  BROADCASTING
  MATCHED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  DONE
  CANCELLED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  QUOTE_CARD
  SYSTEM_LOG
  QUOTE_RESPONSE
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUPERSEDED
  CANCELLED
}

enum AssignmentAction {
  ASSIGNED
  UNASSIGNED
  REJECTED
  MANUAL_CANCEL
  SYSTEM_AUTO_CANCEL
}

enum AccessLevel {
  BASIC
  ADVANCED
}

enum SessionType {
  AI_DIAGNOSIS
  DIRECT_BOOKING
}

enum RagDocumentKind {
  TROUBLESHOOTING_GUIDE
  REPAIR_POLICY
  PRICE_TABLE
  DEVICE_MANUAL
  FAQ
  INTERNAL_NOTE
}

enum RagDocumentStatus {
  UPLOADED
  PARSING
  CHUNKING
  EMBEDDING
  READY
  FAILED
  ARCHIVED
}

enum RagFileType {
  PDF
  DOCX
  XLSX
  XLS
  CSV
  TXT
  MD
  HTML
  JSON
  UNKNOWN
}


